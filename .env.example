# ═══════════════════════════════════════════════════════════════════
# CULTR Ventures — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────
APP_NAME=CULTR Ventures Platform
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production

# ── Database (PostgreSQL + pgvector) ────────────────────────────────
DATABASE_URL=postgresql://cultr:CHANGE_ME@postgres:5432/cultr_platform
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Vector Store (Qdrant) ──────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=cultr_knowledge

# ── Auth (JWT) ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Anthropic (Claude) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
CLAUDE_PRIMARY_MODEL=claude-opus-4-6
CLAUDE_EXECUTION_MODEL=claude-sonnet-4-6
CLAUDE_MONITORING_MODEL=claude-haiku-4-5-20251001

# ── Local LLM (vLLM on GPU node — 10.0.0.2) ───────────────────────
VLLM_URL=http://10.0.0.2:8080
VLLM_MODEL=google/gemma-2-9b-it-AWQ

# ── Local Embeddings (GPU node) ────────────────────────────────────
EMBEDDINGS_URL=http://10.0.0.2:8081
EMBEDDINGS_MODEL=BAAI/bge-large-en-v1.5

# ── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_STARTER=price_CHANGE_ME
STRIPE_PRICE_GROWTH=price_CHANGE_ME
STRIPE_PRICE_ENTERPRISE=price_CHANGE_ME

# ── Virtuals ACP ───────────────────────────────────────────────────
ACP_WALLET_KEY=CHANGE_ME
ACP_RUNTIME_URL=http://acp-runtime:18790

# ── Cloudflare ──────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=CHANGE_ME
CLOUDFLARE_ACCOUNT_ID=CHANGE_ME
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# ── Hetzner ────────────────────────────────────────────────────────
HETZNER_AX52_IP=CHANGE_ME
HETZNER_CLOUD_TOKEN=CHANGE_ME

# ── PostgreSQL (used by docker-compose for the postgres container) ──
POSTGRES_DB=cultr_platform
POSTGRES_USER=cultr
POSTGRES_PASSWORD=CHANGE_ME

# ── Grafana ─────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
